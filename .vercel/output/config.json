{
  "version": 3,
  "routes": [
    {
      "handle": "error"
    },
    {
      "status": 404,
      "src": "^(?!/api).*$",
      "dest": "/404.html"
    }
  ],
  "framework": {
    "version": "16.2.0"
  },
  "crons": [
    {
      "path": "/api/v1/cron/judge",
      "schedule": "0 0 * * *"
    }
  ]
}
